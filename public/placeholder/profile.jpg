<svg width="400" height="500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F7B9C8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f5a5b8;stop-opacity:1" />
