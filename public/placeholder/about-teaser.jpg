<svg width="600" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f8f9fa;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#F7B9C8;stop-opacity:0.3" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="url(#bg)"/>
  <rect x="50" y="50" width="500" height="300" fill="white" stroke="#F7B9C8" stroke-width="2" rx="20"/>
  <rect x="100" y="100" width="400" height="200" fill="#F7B9C8" opacity="0.2" rx="10"/>
  <circle cx="200" cy="150" r="30" fill="#F7B9C8" opacity="0.6"/>
  <rect x="250" y="130" width="200" height="40" fill="#F7B9C8" opacity="0.4" rx="5"/>
  <rect x="250" y="180" width="150" height="20" fill="#F7B9C8" opacity="0.3" rx="3"/>
  <text x="300" y="250" text-anchor="middle" fill="#F7B9C8" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Arbeitsplatz</text>
  <text x="300" y="270" text-anchor="middle" fill="#F7B9C8" font-family="Arial, sans-serif" font-size="14">Julia bei der Arbeit</text>
</svg>
